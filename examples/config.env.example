# Copy to $XDG_DATA_HOME/claude-session-guard/config.env (or
# ~/.local/share/claude-session-guard/config.env by default) to enable Slack.
# Without these, claude-session-guard still works — it just runs local-only.

# Slack Bot token — needs chat:write and reactions:write scopes.
SLACK_BOT_TOKEN=xoxb-replace-me

# Channel to post session threads in. Bot must be a member.
SLACK_CHANNEL_ID=C0123456789
